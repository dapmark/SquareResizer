<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <UseWPF>true</UseWPF>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AssemblyName>SquareResizer</AssemblyName>
	<AssemblyTitle>DapLine SquareResizer</AssemblyTitle>
	<Product>DapLine SquareResizer</Product>
	<Company>DapLine</Company>
	<Authors>DapLine</Authors>
	<Copyright>© 2026 DapLine</Copyright>
	  
	<Version>0.09</Version>
	<AssemblyVersion>0.0.9.0</AssemblyVersion>
	<FileVersion>0.0.9.0</FileVersion>
	<InformationalVersion>0.09</InformationalVersion>

	<ApplicationIcon>app.ico</ApplicationIcon>
    <Platforms>AnyCPU;x64</Platforms>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Magick.NET-Q8-AnyCPU" Version="14.13.1" />
  </ItemGroup>

  <ItemGroup>
    <None Include="settings.txt" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

  <ItemGroup>
    <None Remove="app.ico" />
    <Resource Include="app.ico" />
  </ItemGroup>

</Project>
