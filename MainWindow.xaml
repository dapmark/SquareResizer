<Window x:Class="ImageSquareResizer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SquareResizer"
        Icon="app.ico"
        SizeToContent="WidthAndHeight"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBackgroundBrush}"
        Focusable="True"
        PreviewKeyDown="OnWindowPreviewKeyDown">

    <Window.Resources>
        <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#F3F3F3" />
        <SolidColorBrush x:Key="DropAreaBackgroundBrush" Color="#F5F5F5" />
        <SolidColorBrush x:Key="DropAreaBorderBrush" Color="#828282" />
        <SolidColorBrush x:Key="MainTextBrush" Color="#464646" />
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#505050" />
        <SolidColorBrush x:Key="ButtonBackgroundBrush" Color="#FAFAFA" />
        <SolidColorBrush x:Key="ButtonHoverBackgroundBrush" Color="#F5F9FF" />
        <SolidColorBrush x:Key="ButtonPressedBackgroundBrush" Color="#E6F2FF" />
        <SolidColorBrush x:Key="ButtonBorderBrush" Color="#AAAAAA" />
        <SolidColorBrush x:Key="AccentBorderBrush" Color="#0078D7" />
        <SolidColorBrush x:Key="InputBackgroundBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="StatusTextBrush" Color="#505050" />
        <Style TargetType="{x:Type ToolTip}">
            <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ButtonBorderBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource MainTextBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="MaxWidth" Value="440" />
            <Setter Property="HasDropShadow" Value="True" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ToolTip}">
                        <Border Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="6"
                        Padding="{TemplateBinding Padding}"
                        SnapsToDevicePixels="True">
                            <TextBlock Text="{Binding Content, RelativeSource={RelativeSource TemplatedParent}}"
                               Foreground="{TemplateBinding Foreground}"
                               FontFamily="{TemplateBinding FontFamily}"
                               FontSize="{TemplateBinding FontSize}"
                               TextWrapping="Wrap"
                               MaxWidth="300" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="StatusFileNameToolTipStyle" TargetType="{x:Type ToolTip}">
            <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ButtonBorderBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource MainTextBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="HasDropShadow" Value="True" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ToolTip}">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <TextBlock Text="{Binding Content, RelativeSource={RelativeSource TemplatedParent}}"
                                       Foreground="{TemplateBinding Foreground}"
                                       FontFamily="{TemplateBinding FontFamily}"
                                       FontSize="{TemplateBinding FontSize}"
                                       TextWrapping="NoWrap" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="RoundedButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource ButtonBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ButtonBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource MainTextBrush}" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="RootBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="{DynamicResource ButtonHoverBackgroundBrush}" />
                                <Setter TargetName="RootBorder" Property="BorderBrush" Value="{DynamicResource AccentBorderBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="{DynamicResource ButtonPressedBackgroundBrush}" />
                                <Setter TargetName="RootBorder" Property="BorderBrush" Value="{DynamicResource AccentBorderBrush}" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="RootBorder" Property="BorderBrush" Value="{DynamicResource AccentBorderBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RoundedTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ButtonBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource MainTextBrush}" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="Padding" Value="4,1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="RootBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="RootBorder" Property="BorderBrush" Value="{DynamicResource AccentBorderBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource MainTextBrush}" />
            <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="Margin" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBorder"
                        Background="{TemplateBinding Background}"
                        Padding="{TemplateBinding Padding}"
                        CornerRadius="4"
                        SnapsToDevicePixels="True">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource ButtonHoverBackgroundBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource ButtonPressedBackgroundBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RoundedComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ButtonBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource MainTextBrush}" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                  Focusable="False"
                                  ClickMode="Press"
                                  IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="RootBorder"
                                        Background="{DynamicResource InputBackgroundBrush}"
                                        BorderBrush="{DynamicResource ButtonBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        SnapsToDevicePixels="True" />
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="RootBorder" Property="Background" Value="{DynamicResource ButtonHoverBackgroundBrush}" />
                                                <Setter TargetName="RootBorder" Property="BorderBrush" Value="{DynamicResource AccentBorderBrush}" />
                                            </Trigger>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="RootBorder" Property="Background" Value="{DynamicResource ButtonPressedBackgroundBrush}" />
                                                <Setter TargetName="RootBorder" Property="BorderBrush" Value="{DynamicResource AccentBorderBrush}" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>

                            <ContentPresenter Margin="8,0,22,0"
                                      VerticalAlignment="Center"
                                      HorizontalAlignment="Left"
                                      IsHitTestVisible="False"
                                      Content="{TemplateBinding SelectionBoxItem}"
                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" />

                            <Path Width="8"
                          Height="4"
                          HorizontalAlignment="Right"
                          VerticalAlignment="Center"
                          Margin="0,0,8,0"
                          Fill="{DynamicResource MainTextBrush}"
                          IsHitTestVisible="False"
                          Data="M 0 0 L 4 4 L 8 0 Z" />

                            <Popup x:Name="PART_Popup"
                           Placement="Bottom"
                           IsOpen="{TemplateBinding IsDropDownOpen}"
                           AllowsTransparency="True"
                           Focusable="False"
                           PopupAnimation="Slide">
                                <Border MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                Margin="0,2,0,0"
                                Padding="2"
                                Background="{DynamicResource InputBackgroundBrush}"
                                BorderBrush="{DynamicResource ButtonBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                SnapsToDevicePixels="True">
                                    <ScrollViewer CanContentScroll="True"
                                          Background="Transparent">
                                        <ItemsPresenter />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModeCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid SnapsToDevicePixels="True">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="18" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border x:Name="CheckBoxBorder"
                            Grid.Column="0"
                            Width="14"
                            Height="14"
                            VerticalAlignment="Center"
                            Background="{DynamicResource InputBackgroundBrush}"
                            BorderBrush="{DynamicResource ButtonBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="3"
                            SnapsToDevicePixels="True" />

                            <Path x:Name="CheckMark"
                          Grid.Column="0"
                          Width="9"
                          Height="7"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                          Data="M 1 3.5 L 3.5 6 L 8 1"
                          Stroke="White"
                          StrokeThickness="2"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"
                          StrokeLineJoin="Round"
                          Visibility="Collapsed" />

                            <ContentPresenter Grid.Column="1"
                                      Margin="4,-1,0,0"
                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                      Content="{TemplateBinding Content}"
                                      ContentTemplate="{TemplateBinding ContentTemplate}"
                                      RecognizesAccessKey="True" />
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CheckBoxBorder" Property="Background" Value="{DynamicResource ButtonHoverBackgroundBrush}" />
                                <Setter TargetName="CheckBoxBorder" Property="BorderBrush" Value="{DynamicResource AccentBorderBrush}" />
                            </Trigger>

                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckBoxBorder" Property="Background" Value="{DynamicResource AccentBorderBrush}" />
                                <Setter TargetName="CheckBoxBorder" Property="BorderBrush" Value="{DynamicResource AccentBorderBrush}" />
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible" />
                            </Trigger>

                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Canvas Width="360"
            Height="477"
            Background="{DynamicResource WindowBackgroundBrush}"
            AllowDrop="True"
            DragEnter="OnDragEnter"
            Drop="OnDrop">

        <TextBlock x:Name="ResizeModeLabel"
                   Canvas.Left="22"
                   Canvas.Top="9"
                   Text="Size"
                   Foreground="{DynamicResource SecondaryTextBrush}"
                   FontFamily="Segoe UI"
                   FontSize="12" HorizontalAlignment="Left" VerticalAlignment="Center"/>

        <ComboBox x:Name="ResizeModeComboBox"
                  Canvas.Left="71"
                  Canvas.Top="5"
                  Width="82"
                  Height="26"
                  Style="{StaticResource RoundedComboBoxStyle}"
                  SelectionChanged="OnResizeModeSelectionChanged" HorizontalAlignment="Left" VerticalAlignment="Center">
            <ComboBoxItem Content="Auto" Tag="auto" />
            <ComboBoxItem Content="Cover" Tag="music_cover" />
        </ComboBox>

        <TextBlock x:Name="QualityLabel"
                   Canvas.Left="22"
                   Canvas.Top="42"
                   Text="Quality"
                   Foreground="{DynamicResource SecondaryTextBrush}"
                   FontFamily="Segoe UI"
                   FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Top"/>

        <TextBox x:Name="QualityTextBox"
                 Canvas.Left="79"
                 Canvas.Top="38"
                 Width="45"
                 Height="26"
                 Style="{StaticResource RoundedTextBoxStyle}"
                 LostFocus="OnQualityLostFocus"
                 PreviewKeyDown="OnQualityPreviewKeyDown"
                 PreviewTextInput="OnQualityPreviewTextInput"
                 PreviewMouseWheel="OnQualityPreviewMouseWheel" HorizontalAlignment="Center" VerticalAlignment="Top"/>

        <TextBlock x:Name="SharpModeLabel"
                   Canvas.Left="163"
                   Canvas.Top="9"
                   Text="Sharp"
                   Foreground="{DynamicResource SecondaryTextBrush}"
                   FontFamily="Segoe UI"
                   FontSize="12"/>

        <ComboBox x:Name="SharpModeComboBox"
                  Canvas.Left="218"
                  Canvas.Top="5"
                  Width="116"
                  Height="26"
                  Style="{StaticResource RoundedComboBoxStyle}"
                  SelectionChanged="OnSharpModeSelectionChanged">
            <ComboBoxItem Content="Standard" Tag="standard" />
            <ComboBoxItem Content="Increased" Tag="increased" />
            <ComboBoxItem Content="High" Tag="high" />
            <ComboBoxItem Content="Maximum" Tag="maximum" />
        </ComboBox>

        <CheckBox x:Name="SmartModeCheckBox"
                  Canvas.Left="130"
                  Canvas.Top="40"
                  Width="100"
                  Height="22"
                  Content="Smart mode"
                  Style="{StaticResource ModeCheckBoxStyle}"
                  Checked="OnSmartModeChanged"
                  Unchecked="OnSmartModeChanged" HorizontalAlignment="Center" VerticalAlignment="Top"/>

        <CheckBox x:Name="ManualModeCheckBox"
                  Canvas.Left="235"
                  Canvas.Top="40"
                  Width="104"
                  Height="22"
                  Content="Manual mode"
                  Style="{StaticResource ModeCheckBoxStyle}"
                  Checked="OnManualModeChanged"
                  Unchecked="OnManualModeChanged" HorizontalAlignment="Center" VerticalAlignment="Top"/>

        <Border x:Name="DropArea"
                Canvas.Left="20"
                Canvas.Top="71"
                Width="320"
                Height="320"
                Background="{DynamicResource DropAreaBackgroundBrush}"
                BorderBrush="{DynamicResource DropAreaBorderBrush}"
                BorderThickness="1"
                CornerRadius="5"
                AllowDrop="True"
                DragEnter="OnDragEnter"
                Drop="OnDrop">
            <Grid x:Name="PreviewHost"
                  ClipToBounds="True"
                  Focusable="True"
                  MouseLeftButtonDown="OnPreviewMouseLeftButtonDown"
                  MouseMove="OnPreviewMouseMove"
                  MouseLeftButtonUp="OnPreviewMouseLeftButtonUp">

                <Image x:Name="PreviewImage"
                       Stretch="Uniform"
                       Visibility="Collapsed"
                       IsHitTestVisible="False" />

                <Viewbox x:Name="DropPlusIcon"
                         Width="140"
                         Height="140"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"
                         IsHitTestVisible="False"
                         Opacity="0.55">
                    <Path Stroke="{DynamicResource DropAreaBorderBrush}"
                          StrokeThickness="2"
                          StrokeLineJoin="Miter"
                          Fill="Transparent"
                          Data="M 40,5 L 60,5 L 60,40 L 95,40 L 95,60 L 60,60 L 60,95 L 40,95 L 40,60 L 5,60 L 5,40 L 40,40 Z"/>
                </Viewbox>

                <Canvas x:Name="CropCanvas"
                        Visibility="Collapsed"
                        Background="Transparent">
                    <Rectangle x:Name="CropOverlay"
                               Stroke="{DynamicResource AccentBorderBrush}"
                               StrokeThickness="2"
                               Fill="#220078D7"
                               Width="100"
                               Height="100"
                               IsHitTestVisible="False" />
                </Canvas>
            </Grid>
        </Border>

        <Button x:Name="OpenButton"
                Canvas.Left="110"
                Canvas.Top="403"
                Width="140"
                Height="40"
                Content="Open file"
                Style="{StaticResource RoundedButtonStyle}"
                Click="OnOpenButtonClick" />

        <Button x:Name="CenterCropButton"
                Canvas.Left="262"
                Canvas.Top="403"
                Width="40"
                Height="40"
                Style="{StaticResource RoundedButtonStyle}"
                Visibility="Collapsed"
                Click="OnCenterCropButtonClick">
            <Viewbox Width="18"
                     Height="18"
                     IsHitTestVisible="False">
                <Canvas Width="20"
                        Height="20">
                    <Path Stroke="{DynamicResource MainTextBrush}"
                          StrokeThickness="1.8"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"
                          StrokeLineJoin="Round"
                          Fill="Transparent"
                          Data="M 10,2 L 10,18 M 2,10 L 18,10 M 6,6 L 14,6 L 14,14 L 6,14 Z" />
                </Canvas>
            </Viewbox>
        </Button>


        <Button x:Name="SettingsButton"
                Canvas.Left="312"
                Canvas.Top="409"
                Width="28"
                Height="28"
                Style="{StaticResource RoundedButtonStyle}"
                Click="OnSettingsButtonClick">
            <Viewbox Width="16"
                     Height="16"
                     IsHitTestVisible="False">
                <Canvas Width="24"
                        Height="24">
                    <Path Stroke="{DynamicResource MainTextBrush}"
                          StrokeThickness="2"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"
                          StrokeLineJoin="Round"
                          Fill="Transparent"
                          Data="M9.671 4.136a2.34 2.34 0 0 1 4.659 0 2.34 2.34 0 0 0 3.319 1.915 2.34 2.34 0 0 1 2.33 4.033 2.34 2.34 0 0 0 0 3.831 2.34 2.34 0 0 1-2.33 4.033 2.34 2.34 0 0 0-3.319 1.915 2.34 2.34 0 0 1-4.659 0 2.34 2.34 0 0 0-3.32-1.915 2.34 2.34 0 0 1-2.33-4.033 2.34 2.34 0 0 0 0-3.831A2.34 2.34 0 0 1 6.35 6.051a2.34 2.34 0 0 0 3.319-1.915" />
                    <Ellipse Canvas.Left="9"
                             Canvas.Top="9"
                             Width="6"
                             Height="6"
                             Stroke="{DynamicResource MainTextBrush}"
                             StrokeThickness="2"
                             Fill="Transparent" />
                </Canvas>
            </Viewbox>
        </Button>

        <TextBlock x:Name="StatusTextBlock"
                   Canvas.Left="20"
                   Canvas.Top="451"
                   Width="320"
                   Height="18"
                   Text=""
                   TextAlignment="Center"
                   TextTrimming="CharacterEllipsis"
                   Foreground="{DynamicResource StatusTextBrush}"
                   FontFamily="Segoe UI"
                   FontSize="11" />
    </Canvas>
</Window>